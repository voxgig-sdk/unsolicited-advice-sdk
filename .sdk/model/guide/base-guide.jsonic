# Guide

guide: {
  metrics: count: entity: 1
  metrics: count: path: 3
  metrics: count: method: 3

  entity: advice: {
    path: "/api/advice": {
      op: load: method: *GET
      op: load: transform: res: *("`body.advice`")|top
    }
    path: "/api/advice/all": {
      action: "all": {}
      op: list: method: *GET
    }
    path: "/api/advice/{id}": {
      op: load: method: *GET
      op: load: transform: res: *("`body.advice`")|top
    }
  }

}